# Copy this file to `.env`, then fill in your real SMTP account values.
# Do not commit `.env`; it contains secrets and is already ignored by `.gitignore`.

# Gmail example:
# 1. Enable 2-Step Verification in your Google account.
# 2. Create an App Password.
# 3. Use the app password as SMTP_PASS; do not use your Gmail login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-address@gmail.com

# `npm run check-smtp` sends a test email here.
SMTP_TEST_TO=receiver@example.com

# QQ Mail example:
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-address@qq.com
# SMTP_PASS=your-qq-mail-authorization-code
# SMTP_FROM=your-address@qq.com
# SMTP_TEST_TO=receiver@example.com
